# ==========================================================
# Carousel AI Studio — Environment Variables
# Copy this file to .env.local and fill in your values.
# The app works in demo mode without any API keys set.
# ==========================================================

# OpenAI API Key (optional — for GPT-4 copy + DALL-E 3 images)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Perplexity API Key (optional — for real-time web research)
# Get yours at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key

# NextAuth Secret (required only if you enable auth)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret

# Supabase (optional — for cloud persistence)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Database URL (optional — for Postgres persistence)
DATABASE_URL=your_database_url
